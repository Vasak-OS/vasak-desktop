{
  "name": "vasak-desktop",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "vue-tsc --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build --features wayland",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write . && bunx --bun biome format --write .",
    "format": "bunx --bun biome format --write ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "@tauri-apps/plugin-shell": "~2.3.5",
    "@vasakgroup/plugin-bluetooth-manager": "^2.0.0",
    "@vasakgroup/plugin-config-manager": "^2.2.4",
    "@vasakgroup/plugin-network-manager": "^2.1.0",
    "@vasakgroup/plugin-user-data": "^2.0.0",
    "@vasakgroup/plugin-vicons": "^2.0.0",
    "@vasakgroup/vue-libvasak": "~0.2.3",
    "path": "^0.12.7",
    "pinia": "^3.0.4",
    "url": "^0.11.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vue-tsc": "^3.3.2"
  }
}
